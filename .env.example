# Star Cadet Academy - Environment Variables
# Copy this file to .env.local for development

# =============================================
# FRONTEND (used by Vite — prefix with VITE_)
# =============================================
# Leave blank to use localStorage-only mode (no backend needed)
# Set to your Vercel URL in production to enable serverless backend
VITE_API_URL=
VITE_APP_NAME=Star Cadet Academy

# =============================================
# BACKEND (Vercel Serverless Functions)
# Set these in the Vercel Dashboard → Settings → Environment Variables
# =============================================

# Vercel Postgres — auto-populated when you link a Vercel Postgres database.
# The code accepts either POSTGRES_URL or DATABASE_URL (checks both).
# POSTGRES_URL=
# DATABASE_URL=

# JWT secret — generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional: restrict CORS to your domain
# FRONTEND_URL=https://your-app.vercel.app

# =============================================
# EMAIL (Nodemailer / SMTP — for welcome emails)
# Works with any SMTP provider (Gmail, SendGrid, Mailgun, etc.)
# Leave blank to disable email sending.
# =============================================
# APP_NAME=Star Cadet Academy
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Star Cadet Academy <no-reply@example.com>

